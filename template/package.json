		"@types/bun": "latest",
		"@clack/prompts": "latest",
		"typescript": "latest",
		"prettier": "latest",
		"@involvex/prettier-config": "0.0.5",
		"eslint": "^10.6.0",
		"@eslint/js": "^10.0.1",
		"typescript-eslint": "^8.62.0"
	},
	"prettier": "@involvex/prettier-config"
