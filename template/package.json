{
	"name": "{{PACKAGE_NAME}}",
	"version": "0.1.0",
	"description": "{{DESCRIPTION}}",
	"author": "{{AUTHOR}}",
	"keywords": [
		"opencode",
		"opencode-plugin",
		"plugin"
	],
	"license": "MIT",
	"files": [
		"src"
	],
	"type": "module",
