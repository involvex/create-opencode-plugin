{
	"name": "create-opencode-plugin",
	"version": "0.0.1",
	"description": "Create a new OpenCode plugin with a single command",
	"keywords": [
		"create",
		"opencode",
		"opencode-plugin",
		"plugin",
		"scaffold",
		"template"
	],
	"homepage": "https://github.com/kynnyhsap/create-opencode-plugin",
	"bugs": {
		"url": "https://github.com/kynnyhsap/create-opencode-plugin/issues"
	},
	"license": "MIT",
	"author": "Andrew Pashynnyk",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kynnyhsap/create-opencode-plugin.git"
	},
	"bin": {
		"create-opencode-plugin": "dist/index.js"
	},
	"files": [
		"dist",
		"template"
	],
	"type": "module",
	"scripts": {
		"dev": "bun run src/index.ts",
		"build": "rm -rf dist && bun build src/index.ts --outdir dist --target node --packages external",
		"fmt": "oxfmt . --write",
		"fmt:check": "oxfmt . --check",
		"lint": "oxlint src/",
		"lint:fix": "oxlint src/ --fix",
		"prepublishOnly": "bun run build",
		"check": "bun fmt && bun lint && bun typecheck",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"commander": "^14.0.3"
	},
	"devDependencies": {
		"@types/bun": "^1.3.8",
		"@types/node": "^25.2.0",
		"oxfmt": "^0.27.0",
		"oxlint": "^1.42.0",
		"typescript": "^5.7.2"
	}
}
