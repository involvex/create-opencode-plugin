{
	"name": "@involvex/create-opencode-plugin",
	"version": "0.0.1",
	"description": "Create a new OpenCode plugin with a single command",
	"keywords": [
		"create",
		"opencode",
		"opencode-plugin",
		"plugin",
		"scaffold",
		"template"
	],
	"homepage": "https://github.com/involvex/create-opencode-plugin",
	"bugs": {
		"url": "https://github.com/involvex/create-opencode-plugin/issues"
	},
	"license": "MIT",
	"author": "InvolveX",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/involvex/create-opencode-plugin.git"
	},
	"bin": {
		"create-opencode-plugin": "dist/index.js"
	},
	"files": [
		"dist",
		"template"
	],
	"type": "module",
	"scripts": {
		"dev": "bun run src/index.ts",
		"build": "rm -rf dist && bun build src/index.ts --outdir dist --target node --packages external",
		"fmt": "oxfmt . --write",
		"fmt:check": "oxfmt . --check",
		"lint": "oxlint src/",
		"lint:fix": "oxlint src/ --fix",
		"prepublishOnly": "bun run build",
		"check": "bun fmt && bun lint:fix && bun typecheck",
		"typecheck": "tsc --noEmit",
		"prebuild": "bun run check"
	},
	"dependencies": {
		"@clack/prompts": "^1.6.0",
		"commander": "^15.0.0"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/bun": "^1.3.14",
		"@types/node": "^26.0.1",
		"eslint": "^10.6.0",
		"oxfmt": "^0.56.0",
		"oxlint": "^1.71.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.62.0"
	}
}
